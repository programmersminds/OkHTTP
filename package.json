{
  "name": "react-native-secure-http",
  "version": "2.0.0",
  "description": "Secure HTTP client with TLS 1.3 helpers and an axios-like API for React Native",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "react-native": {
    "android": {
      "sourceDir": "src/android",
      "packageImportPath": "import com.securehttp.SecureHttpPackage;",
      "packageInstance": "new SecureHttpPackage()"
    },
    "ios": {
      "podspecPath": "react-native-secure-http.podspec"
    }
  },

  "scripts": {
    "test": "echo \"No tests yet\"",
    "postinstall": "echo \"✅ react-native-secure-http installed successfully\""
  },
  "keywords": [
    "react-native",
    "tls",
    "https",
    "security",
    "axios",
    "fetch",
    "http"
  ],
  "author": "Osarinmwian Noel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/programmersminds/OkHTTP.git"
  },
  "homepage": "https://github.com/programmersminds/OkHTTP#readme",
  "bugs": {
    "url": "https://github.com/programmersminds/OkHTTP/issues"
  },
  "engines": {
    "node": ">=12.0.0",
    "npm": ">=6.0.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-native-view-shot": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {},
  "packageManager": "yarn@1.22.0 || npm@6.0.0"
}
